@model draftapp.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h1>Student Details</h1>

<hr />

<dl>
    <dt>ID</dt>
    <dd>@Model.StudentId</dd>

    <dt>Full Name</dt>
    <dd>@Model.FullName</dd>

    <dt>Email</dt>
    <dd>@Model.Email</dd>

    <dt>Phone</dt>
    <dd>@Model.Phone</dd>

    <dt>Status</dt>
    <dd>@Model.Status</dd>

    <dt>Join Date</dt>
    <dd>@Model.JoinDate.ToString("yyyy-MM-dd")</dd>

    <dt>Created At</dt>
    <dd>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</dd>
</dl>

<div>
    <a asp-action="Edit" asp-route-id="@Model.StudentId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
