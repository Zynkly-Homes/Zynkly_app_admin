@model draftapp.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>

<h3>Are you sure you want to delete this student?</h3>

<hr />

<dl>
    <dt>ID</dt>
    <dd>@Model.StudentId</dd>

    <dt>Full Name</dt>
    <dd>@Model.FullName</dd>

    <dt>Email</dt>
    <dd>@Model.Email</dd>

    <dt>Phone</dt>
    <dd>@Model.Phone</dd>

    <dt>Status</dt>
    <dd>@Model.Status</dd>

    <dt>Join Date</dt>
    <dd>@Model.JoinDate.ToString("yyyy-MM-dd")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="StudentId" />
    <button type="submit">Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
