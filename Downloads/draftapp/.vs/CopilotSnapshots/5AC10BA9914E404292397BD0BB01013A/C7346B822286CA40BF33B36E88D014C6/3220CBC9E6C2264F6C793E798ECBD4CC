@model draftapp.Models.Student

@{
    ViewData["Title"] = "Add Student";
}

<h1>Add Student</h1>

<hr />
<form asp-action="Create">
    <div asp-validation-summary="ModelOnly"></div>

    <div>
        <label asp-for="FullName">Full Name</label><br />
        <input asp-for="FullName" />
        <span asp-validation-for="FullName"></span>
    </div>
    <br />

    <div>
        <label asp-for="Email">Email</label><br />
        <input asp-for="Email" type="email" />
        <span asp-validation-for="Email"></span>
    </div>
    <br />

    <div>
        <label asp-for="Phone">Phone</label><br />
        <input asp-for="Phone" />
        <span asp-validation-for="Phone"></span>
    </div>
    <br />

    <div>
        <label asp-for="Status">Status</label><br />
        <select asp-for="Status">
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
            <option value="Graduated">Graduated</option>
        </select>
        <span asp-validation-for="Status"></span>
    </div>
    <br />

    <div>
        <label asp-for="JoinDate">Join Date</label><br />
        <input asp-for="JoinDate" type="date" />
        <span asp-validation-for="JoinDate"></span>
    </div>
    <br />

    <div>
        <button type="submit">Create</button>
        <a asp-action="Index">Back to List</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
