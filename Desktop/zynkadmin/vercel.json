{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "installCommand": "npm install --legacy-peer-deps && cd zynkly-admin/backend && npm install --legacy-peer-deps",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
